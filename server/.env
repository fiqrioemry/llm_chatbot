# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════════════════════

APP_PORT=8080
APP_MODE=development                          # development | production
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:8080
GLOBAL_RATE_LIMIT=60   
GLOBAL_RATE_LIMIT_WINDOW=60                     # max requests per minute per IP, default: 60

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE — MySQL
# format: user:pass@tcp(host:port)/dbname?charset=utf8mb4&parseTime=True&loc=UTC
# ═══════════════════════════════════════════════════════════════════════════════

DATABASE_DSN=mysql:mysecurepassword@tcp(localhost:3306)/chatbot?charset=utf8mb4&parseTime=True&loc=UTC

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════════════════════════════════

REDIS_URL=redis://:mysecureredispassword@localhost:6379

# ═══════════════════════════════════════════════════════════════════════════════
# AUTH — Access Token + Refresh Token
# ═══════════════════════════════════════════════════════════════════════════════

ACCESS_TOKEN_SECRET=change-me-to-a-very-long-random-string-min-32-chars
ACCESS_TOKEN_EXP_SEC=900                      # 15 menit
REFRESH_TOKEN_EXP_SEC=604800                  # 7 hari

# Email verification link TTL
VERIFY_EMAIL_EXP_SEC=86400                    # 24 jam

# Password reset link TTL
RESET_PASSWORD_EXP_SEC=3600                   # 1 jam

# OAuth CSRF state TTL
OAUTH_STATE_TTL_SEC=600                       # 10 menit

# ═══════════════════════════════════════════════════════════════════════════════
# SMTP — Email (contoh: Gmail App Password)
# ═══════════════════════════════════════════════════════════════════════════════

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=foemry@gmail.com
SMTP_PASS=vndafdvrsmrbpelj           # Google App Password, bukan password akun
SMTP_FROM=no-reply@yourapp.com

# ═══════════════════════════════════════════════════════════════════════════════
# MINIO — Object Storage
# ═══════════════════════════════════════════════════════════════════════════════
MINIO_ENDPOINT=storage.ahmadfiqrioemry.com                # tanpa http:// — minio-go handle sendiri
MINIO_ACCESS_KEY=oemry
MINIO_SECRET_KEY=8sUg8z4xmt7pFYZ
MINIO_BUCKET=ecommerce
MINIO_USE_SSL=true                           # true jika production dengan HTTPS

# ═══════════════════════════════════════════════════════════════════════════════
# OAUTH — Google
# Buat di: https://console.cloud.google.com → APIs & Services → Credentials
# ═══════════════════════════════════════════════════════════════════════════════

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/v1/auth/google/callback

# ═══════════════════════════════════════════════════════════════════════════════
# OAUTH — GitHub
# Buat di: https://github.com/settings/developers → OAuth Apps
# ═══════════════════════════════════════════════════════════════════════════════

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/v1/auth/github/callback